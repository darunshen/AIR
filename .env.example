# AIR runtime
AIR_VM_RUNTIME=local

# Firecracker runtime assets
# AIR_FIRECRACKER_BIN=/absolute/path/to/firecracker
# AIR_FIRECRACKER_KERNEL=/absolute/path/to/vmlinux
# AIR_FIRECRACKER_ROOTFS=/absolute/path/to/rootfs.ext4
# AIR_KVM_DEVICE=/dev/kvm

# Reference agent planner
AIR_AGENT_PROVIDER=openai
AIR_AGENT_MODEL=gpt-5.4-mini
AIR_AGENT_ESCALATION_MODEL=gpt-5.4
AIR_AGENT_REASONING=medium

# Primary provider
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Supported alternative provider
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# Example:
# AIR_AGENT_PROVIDER=deepseek
# AIR_AGENT_MODEL=deepseek-chat

# Optional future providers
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
